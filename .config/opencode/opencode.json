{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "permission": {
    "external_directory": "allow"
  },
  "plugin": [
    "@tarquinen/opencode-dcp",
    "@plannotator/opencode@latest"
  ],
  "model": "nvidia/z-ai/glm-5.2",
  "agent": {
    "plan": {
      "model": "nvidia/moonshotai/kimi-k2.6"
    },
    "build": {
      "model": "nvidia/minimaxai/minimax-m3"
    },
    "docs": {
      "model": "nvidia/z-ai/glm-5.2"
    }
  },
  "small_model": "nvidia/minimaxai/minimax-m3",
  "mcp": {
    "kagi": {
      "type": "local",
      "command": ["uvx", "kagimcp"],
      "enabled": true,
      "environment": {
        "KAGI_API_KEY": "sbq4R3Cy56ZsvWPBBOp7jXs64J0_R-WnLu49TcylZhA.yTR89ZsH8H1hMmZj3yl_aI3Socl0ksBSPYZMkfW4vh8"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    }
  },
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "z-ai/glm-5.2": {
          "name": "GLM 5.1"
        },
        "moonshotai/kimi-k2.6": {
          "name": "Kimi K2.6"
        },
        "minimaxai/minimax-m2.7": {
          "name": "MiniMax M2.7"
        },
        "minimaxai/minimax-m3": {
          "name": "MiniMax M3"
        }
      }
    },
    "opencode-go": {
      "models": {
        "kimi-k2.6": {
          "limit": { "context": 262144, "output": 32768 },
          "variants": {
            "high": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 32000 } }
          }
        },
        "deepseek-v4-flash": {
          "variants": {
            "high": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 32000 } }
          }
        },
        "deepseek-v4-pro": {
          "variants": {
            "high": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 32000 } }
          }
        },
        "glm-5.2": {
          "variants": {
            "high": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 32000 } }
          }
        }
      }
    }
  }
}
