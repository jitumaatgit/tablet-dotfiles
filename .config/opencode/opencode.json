{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "permission": {
    "external_directory": "allow"
  },
  "plugin": [
    "@tarquinen/opencode-dcp",
    "@plannotator/opencode@latest"
  ],
  "model": "deepseek/deepseek-v4-pro",
  "agent": {
    "plan": {
      "model": "deepseek/deepseek-v4-pro",
      "variant": "high"
    },
    "build": {
      "model": "deepseek/deepseek-v4-pro",
      "variant": "high"
    },
    "docs": {
      "model": "deepseek/deepseek-v4-pro",
      "variant": "high"
    }
  },
  "small_model": "deepseek/deepseek-v4-flash",
  "mcp": {
    "kagi": {
      "type": "local",
      "command": ["uvx", "kagimcp"],
      "enabled": true,
      "environment": {
        "KAGI_API_KEY": "sbq4R3Cy56ZsvWPBBOp7jXs64J0_R-WnLu49TcylZhA.yTR89ZsH8H1hMmZj3yl_aI3Socl0ksBSPYZMkfW4vh8"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    }
  },
  "provider": {
    /*
    "opencode-go": {
      "models": {
        "kimi-k2.6": {
          "limit": { "context": 262144, "output": 32768 },
          "variants": {
            "high": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 32000 } }
          }
        },
        "deepseek-v4-flash": {
          "variants": {
            "high": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 32000 } }
          }
        }
      }
    },
    */
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "limit": {
            "context": 1048576,
            "output": 262144
          },
          "variants": {
            "high": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 8192
              }
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro",
          "limit": {
            "context": 1048576,
            "output": 262144
          },
          "variants": {
            "high": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 8192
              }
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            }
          }
        }
      }
    }
  }
}
